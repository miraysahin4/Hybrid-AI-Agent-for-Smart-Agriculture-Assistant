def llm_answer(message: str, lang: str, state: dict, sensors: dict):
    system_msg = f"""
You are a Smart Agriculture Decision Support AI.

You MUST follow this workflow:

STEP 1 — Analysis
- Analyze the selected polygon and target points.
- Consider climate, soil, vegetation and region.

STEP 2 — Sensor Recommendation
- Recommend the MOST USEFUL sensor types among:
  {SENSOR_TYPES}
- Explain WHY each sensor is needed.

STEP 3 — Confirmation Question (IMPORTANT)
- Ask the user clearly:
  "Do you accept these sensor recommendations, or would you like to modify them?"

STEP 4 — (Only if user accepts)
- Prepare a coverage requirement structure:
  - Targets are indexed as i = 1,2,3,...
  - Sensors are indexed as j = 1,2,3,...
  - f_ij = 1 if sensor j is required at target i, else 0
- Present this as a matrix-like explanation (textual description is enough).

Context:
- Language: {lang}
- Polygon: {state.get("polygon")}
- Targets: {state.get("targets")}
- User-provided sensor data (if any): {sensors}

Rules:
- Be technical but understandable.
- Use bullet points.
- Do NOT invent real measurements.
- If data is missing, say so and ask.
"""


    print("🔥 [LLM] llm_answer fonksiyonuna girildi", flush=True)
    print("🔥 [LLM] API KEY var mı?:", bool(ANTHROPIC_API_KEY), flush=True)
    if ANTHROPIC_API_KEY:
        print("🔥 [LLM] KEY başlangıcı:", ANTHROPIC_API_KEY[:7], flush=True)

    if not ANTHROPIC_API_KEY or not ANTHROPIC_API_KEY.startswith("sk-ant-"):
        print("❌ [LLM] ANTHROPIC_API_KEY yok veya geçersiz", flush=True)
        return None

    try:
        print("🚀 [LLM] Claude API çağrısı yapılacak...", flush=True)
        client = Anthropic(api_key=ANTHROPIC_API_KEY)

        # ... senin mevcut kod aynı kalsın ...

        resp = client.messages.create(
            model="claude-sonnet-4-20250514",
            max_tokens=900,
            temperature=0.35,
            system=system_msg,
            messages=[{"role": "user", "content": message}],
        )

        if not resp.content or not resp.content[0].text.strip():
          return None

        text = resp.content[0].text.strip()
        return text

    except Exception as e:
        print("⚠️ [LLM] Claude API hatası:", repr(e), flush=True)
        return None



